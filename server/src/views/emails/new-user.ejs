<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Welcome to <%= appName || "PickOne" %></title>
</head>

<body style="margin:0;padding:40px 16px;background:#f7f7f7;font-family:Arial,Helvetica,sans-serif;">

  <table width="100%" cellpadding="0" cellspacing="0">
    <tr>
      <td align="center">

        <table width="100%" style="max-width:600px;">
          <%- include("partials/navbar") %>

          <tr>
            <td style="background:#fff;border:1px solid #e5e5e5;border-radius:10px;padding:40px;text-align:center;">

              <div style="font-size:42px;">🎉</div>

              <h2 style="margin:16px 0 12px;color:#171717;">
                Welcome, <%= name || "there" %>!
              </h2>

              <p style="margin:0 0 28px;color:#666;line-height:1.6;">
                Your <strong><%= appName || "PickOne" %></strong> account has been created successfully.
                Start creating polls and let people vote.
              </p>

              <a
                href="<%= loginUrl %>"
                style="display:inline-block;padding:12px 24px;background:#171717;color:#fff;text-decoration:none;border-radius:6px;font-weight:600;"
              >
                Get Started →
              </a>

            </td>
          </tr>

          <%- include("partials/footer") %>
        </table>

      </td>
    </tr>
  </table>

</body>
</html>