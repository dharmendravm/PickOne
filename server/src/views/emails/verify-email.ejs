<!DOCTYPE html>
<html>
<head>
  <meta charset="UTF-8" />
  <title>Verify Email</title>
</head>

<body style="font-family: Arial, sans-serif; background:#f5f5f5; padding:40px;">

  <div style="max-width:500px; margin:auto; background:#fff; padding:30px; border-radius:8px; text-align:center;">

    <h2>Verify Your Email</h2>

    <p>
      Hi <strong><%= name %></strong>,
    </p>

    <p>
      Please verify your email address to activate your account.
    </p>

    <a
      href="<%= verificationUrl %>"
      style="display:inline-block; margin:20px 0; padding:12px 24px; background:#171717; color:#fff; text-decoration:none; border-radius:6px;"
    >
      Verify Email
    </a>

    <p style="font-size:13px; color:#666;">
      This link expires in <%= expiresIn %>.
    </p>

    <p style="font-size:13px; color:#666;">
      If you didn't create this account, you can safely ignore this email.
    </p>

  </div>

</body>
</html>