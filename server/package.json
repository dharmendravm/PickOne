    "ejs": "^6.0.1",
    "express": "^5.2.1",
    "nodemailer": "^9.0.1",
    "pg": "^8.22.0",
    "uuid": "^14.0.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
